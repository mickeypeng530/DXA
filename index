    fb:'ISCD：亂經 = 停經過渡期，應做全身 + TBS + FRAX。「未滿一年不算停經」是常見誤解。'},

  { id:9, badge:'報告設定 ⑥', scenario:'60歲病人，兩年前曾做骨密度全身檢查（L spine、R hip、L hip），今日再次回診。',
    text:'今日的骨密度報告應包含哪些項目？', ans:'C', link:'section-setting6', linkText:'設定 ⑥ Trending',
    opts:['只做 BMD 三部位即可','BMD 三部位 + Trending（L spine, Dual femur 頸）+ TBS + FRAX','BMD 三部位 + Trending（L spine, Dual femur total）+ TBS + FRAX','BMD 三部位 + TBS + FRAX（無需 trending，兩年才一次）'],
    fb:'有前次資料時須做 trending。Dual femur 應選 <b>total（全部均值）</b>，非頸部（頸部僅用於診斷比較）。60歲符合 TBS + FRAX 條件。'}
];

const LETTERS = ['A','B','C','D'];
let cur = 0, results = new Array(9).fill(null); // null = unanswered, true/false = correct/wrong

// ══ Start ══
function startQuiz() {
  document.getElementById('quiz-intro').style.display = 'none';
  document.getElementById('quiz-area').style.display = 'block';
  buildDots();
  renderQ(0);
}

function buildDots() {
  const d = document.getElementById('dots');
  d.innerHTML = '';
  for (let i = 0; i < 9; i++) {
    const dot = document.createElement('div');
    dot.className = 'dot' + (i === 0 ? ' current' : '');
    dot.id = 'dot-' + i;
    d.appendChild(dot);
  }
}

// ══ Render question ══
function renderQ(idx) {
  cur = idx;
  const q = QS[idx];
  const c = document.getElementById('q-container');

  let html = `<div class="q-card">
    <div class="q-badge">${q.badge}</div>
    <div class="q-scenario">${q.scenario}</div>`;

  if (q.table) {
    html += `<table class="mini-table"><tr><th>椎體</th><th>T-Score</th></tr>
      <tr><td>L1</td><td>0.1</td></tr><tr><td>L2</td><td>0.3</td></tr>
      <tr><td>L3</td><td>−0.3</td></tr><tr><td>L4</td><td>−1.3</td></tr></table>`;
  }

  if (q.images) {
    html += '<div class="img-row">';
    q.images.forEach(im => {
      html += `<div class="img-box">
        <img src="${im.src}" alt="${im.cap}" onerror="this.parentElement.innerHTML='<div style=\\'padding:30px;background:var(--bg2);border-radius:8px;color:var(--text2);font-size:0.85em;\\'>${im.cap}</div>'">
        <div class="cap">${im.cap}</div></div>`;
    });
    html += '</div>';
  }

  html += `<div class="q-text">${q.text}</div><div class="opts" id="opts">`;

  const answered = results[idx] !== null;
  const ansIdx = LETTERS.indexOf(q.ans);

  q.opts.forEach((o, i) => {
    let cls = 'opt';
    if (answered) {
      cls += ' locked';
      if (i === ansIdx) cls += ' is-correct';
      else if (results[idx] === false && i === userChoices[idx]) cls += ' is-wrong';
    }
    html += `<button class="${cls}" ${answered ? 'disabled' : ''} onclick="pick(${idx},${i})">
      <span class="letter">${LETTERS[i]}</span><span>${o}</span></button>`;
  });

  html += '</div>';

  // Feedback
  if (answered) {
    const ok = results[idx];
    html += `<div class="fb show ${ok ? 'ok' : 'nope'}">${q.fb}<br>
      <a class="go-link" href="#" onclick="goTeach('${q.link}');return false;">📖 ${q.linkText}</a></div>`;
  }

  html += '</div>';
  c.innerHTML = html;

  // Update label & dots
  document.getElementById('qLabel').textContent = `題目 ${idx+1} / 9`;
  for (let i = 0; i < 9; i++) {
    const dot = document.getElementById('dot-' + i);
    dot.className = 'dot';
    if (i === idx) dot.classList.add('current');
    if (results[i] === true) dot.classList.add('done-correct');
    else if (results[i] === false) dot.classList.add('done-wrong');
  }

  // Nav buttons
  document.getElementById('prevBtn').disabled = (idx === 0);
  const nBtn = document.getElementById('nextBtn');
  if (idx === 7 && results.every(r => r !== null)) {
    nBtn.textContent = '查看結果';
    nBtn.onclick = () => showSummary();
  } else {
    nBtn.textContent = '下一題 →';
    nBtn.onclick = () => navQ(1);
    nBtn.disabled = (idx === 7);
  }
}

let userChoices = new Array(9).fill(null);

function pick(qIdx, optIdx) {
  if (results[qIdx] !== null) return;
  const q = QS[qIdx];
  const ansIdx = LETTERS.indexOf(q.ans);
  userChoices[qIdx] = optIdx;
  results[qIdx] = (optIdx === ansIdx);
  renderQ(qIdx);

  // Auto-advance after 1.5s if not last
  if (qIdx < 8) {
    setTimeout(() => {
      if (cur === qIdx) navQ(1);
    }, 2000);
  } else if (results.every(r => r !== null)) {
    // Last question answered — update button
    const nBtn = document.getElementById('nextBtn');
    nBtn.textContent = '查看結果';
    nBtn.disabled = false;
    nBtn.onclick = () => showSummary();
  }
}

function navQ(dir) {
  const next = cur + dir;
  if (next >= 0 && next < 9) renderQ(next);
}

// ══ Summary ══
function showSummary() {
  document.getElementById('quiz-area').style.display = 'none';
  const s = document.getElementById('quiz-summary');
  const score = results.filter(r => r === true).length;
  const msgs = ['加油！建議複習教學內容','還可以，再練習幾次！','不錯！','很好！','太厲害了！滿分！'];
  const mi = score <= 4 ? 0 : score <= 6 ? 1 : score <= 7 ? 2 : score === 8 ? 3 : 4;

  let html = `<h3>測驗完成</h3>
    <div class="score-circle"><div><span class="num">${score}</span><span class="den"> / 9</span></div></div>
    <div class="msg">${msgs[mi]}</div>`;

  const wrongs = results.map((r,i) => r === false ? i : -1).filter(i => i >= 0);
  if (wrongs.length > 0) {
    html += '<div class="wrong-review"><h4>答錯的題目：</h4>';
    wrongs.forEach(i => {
      const q = QS[i];
      html += `<div class="wr-item"><span style="color:var(--wrong);">✗</span>
        <span>Q${i+1} ${q.badge}</span>
        <a href="#" onclick="goTeach('${q.link}');return false;">→ 複習</a></div>`;
    });
    html += '</div>';
  }

  html += `<button class="start-btn" style="margin-top:20px;" onclick="resetQuiz()">重新作答</button>`;
  s.innerHTML = html;
  s.style.display = 'block';
  s.scrollIntoView({behavior:'smooth', block:'start'});
}

function resetQuiz() {
  results = new Array(9).fill(null);
  userChoices = new Array(9).fill(null);
  cur = 0;
  document.getElementById('quiz-summary').style.display = 'none';
  document.getElementById('quiz-intro').style.display = 'block';
  document.getElementById('quiz-area').style.display = 'none';
  window.scrollTo({top:0, behavior:'smooth'});
}

// ══ Navigation ══
function go(page, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(b => b.classList.remove('active'));
  document.getElementById('pg-' + page).classList.add('active');
  if (btn) btn.classList.add('active');
  window.scrollTo({top:0, behavior:'smooth'});
}

function jumpTo(id) {
  const el = document.getElementById(id);
  if (el) setTimeout(() => el.scrollIntoView({behavior:'smooth', block:'start'}), 50);
}

function goTeach(id) {
  go('teach', document.querySelectorAll('.nav-tab')[1]);
  setTimeout(() => {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({behavior:'smooth', block:'start'});
  }, 150);
}

// ══ Accordion ══
function togAcc(btn) {
  btn.classList.toggle('open');
  btn.nextElementSibling.classList.toggle('open');
}

// ══ Theme ══
function toggleTheme() {
  const d = document.body.dataset.theme === 'dark';
  document.body.dataset.theme = d ? 'light' : 'dark';
  document.getElementById('themeBtn').textContent = d ? '🌙' : '☀️';
}

// ══ Font ══
function setFont(s) {
  document.body.dataset.font = s;
  document.querySelectorAll('.ctrl-btn').forEach((b, i) => {
    if (i < 3) b.classList.toggle('on', ['small','medium','large'][i] === s);
  });
}
</script>

